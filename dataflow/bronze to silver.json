{
	"name": "bronze to silver",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bja_controles_pediatricos",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "bja_controles_prenatales",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "bja_establecimientos_salud",
						"type": "DatasetReference"
					},
					"name": "source3"
				},
				{
					"dataset": {
						"referenceName": "bja_inscripciones",
						"type": "DatasetReference"
					},
					"name": "source4"
				},
				{
					"dataset": {
						"referenceName": "bja_pagos",
						"type": "DatasetReference"
					},
					"name": "source5"
				},
				{
					"dataset": {
						"referenceName": "bja_partos",
						"type": "DatasetReference"
					},
					"name": "source6"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "derivedColumn6"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_pediatrico_id as string,",
				"          ci_nino as string,",
				"          ci_madre as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          peso_nino_kg as string,",
				"          talla_nino_cm as string,",
				"          vacuna_aplicada as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          control_prenatal_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          establecimiento_id as string,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source4",
				"source(output(",
				"          pago_id as string,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as string,",
				"          fecha_pago as string,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source5",
				"source(output(",
				"          parto_id as string,",
				"          ci_madre as string,",
				"          ci_recien_nacido as string,",
				"          establecimiento_id as string,",
				"          fecha_parto as string,",
				"          tipo_parto as string,",
				"          peso_nacimiento_kg as string,",
				"          talla_nacimiento_cm as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source6",
				"source1 derive(fecha_control = coalesce( \r",
				"    toDate(fecha_control, 'yyyy-MM-dd'), \r",
				"    toDate(fecha_control, 'dd/MM/yyyy'), \r",
				"    toDate(fecha_control, 'MM-dd-yyyy'), \r",
				"    toDate(fecha_control, 'yyyy/MM/dd'), \r",
				"    toDate(fecha_control, 'dd-MMM-yyyy'),\r",
				"    toDate(fecha_control, 'MMMM dd, yyyy'),\r",
				"    toDate(fecha_control, \"dd 'de' MMMM 'de' yyyy\")\r",
				"),",
				"          ci_nino = (regexReplace(toString(ci_nino), '[^0-9.]', '')),",
				"          ci_madre = (regexReplace(toString(ci_madre), '[^0-9.]', '')),",
				"          talla_nino_cm = toDecimal(talla_nino_cm),",
				"          peso_nino_kg = toDecimal(peso_nino_kg),",
				"          resultado = case(\r",
				"  in(['nrmal','nORMAL','normal','Nrmal'], resultado), 'Normal',\r",
				"  in(['bAJO pESO','pantallas'], resultado), 'Bajo Peso',\r",
				"  in(['DESNUTRICIÓN LEVE','Desnutriicón Leve','Desnutricion Leve','DESNUTRICIÓN LVEE'], resultado), 'Desnutrición Leve',\r",
				"  resultado\r",
				"),",
				"          vacuna_aplicada = initCap(lower(vacuna_aplicada))) ~> derivedColumn1",
				"source2 derive(ci_beneficiaria = (regexReplace(toString(ci_beneficiaria), '[^0-9.]', '')),",
				"          fecha_control = coalesce( \r",
				"    toDate(fecha_control, 'yyyy-MM-dd'), \r",
				"    toDate(fecha_control, 'dd/MM/yyyy'), \r",
				"    toDate(fecha_control, 'MM-dd-yyyy'), \r",
				"    toDate(fecha_control, 'yyyy/MM/dd'), \r",
				"    toDate(fecha_control, 'dd-MMM-yyyy'),\r",
				"    toDate(fecha_control, 'MMMM dd, yyyy'),\r",
				"    toDate(fecha_control, \"dd 'de' MMMM 'de' yyyy\")\r",
				"),",
				"          peso_madre_kg = toDecimal(peso_madre_kg),",
				"          resultado = case(\r",
				"  in(['nrmal','nORMAL','normal','Nrmal','Noraml','NORMAL'], resultado), 'Normal',\r",
				"  in(['Riesgoo Bajo','pantallas'], resultado), 'Riesgo Bajo',\r",
				"  in(['rIESGO aLTO','Desnutriicón Leve','Desnutricion Leve','DESNUTRICIÓN LVEE','Riesgoo Alto','riesgo alto'], resultado), 'Riesgo Alto',\r",
				"  in(['RIIESGO MODERADO'], resultado), 'Riesgo Moderado',\r",
				"  resultado\r",
				")) ~> derivedColumn2",
				"source3 derive(departamento = case(\r",
				"    in(['CB'], departamento), 'Cochabamba',\r",
				"    in(['LP'], departamento), 'La Paz', \r",
				"    in(['SC'], departamento), 'Santa Cruz',\r",
				"    in(['PT'], departamento), 'Potosi',\r",
				"    in(['CH'], departamento), 'Chuquisaca', \r",
				"    in(['BN'], departamento), 'Beni',\r",
				"    in(['PD'], departamento), 'Pando',\r",
				"    in(['OR'], departamento), 'Oruro', \r",
				"    in(['TJ'], departamento), 'Tarija',\r",
				"departamento\r",
				")) ~> derivedColumn3",
				"source4 derive(ci_beneficiaria = (regexReplace(toString(ci_beneficiaria), '[^0-9.]', '')),",
				"          fecha_inscripcion = coalesce(      toDate(fecha_inscripcion, 'yyyy-MM-dd'),      toDate(fecha_inscripcion, 'dd/MM/yyyy'),      toDate(fecha_inscripcion, 'MM-dd-yyyy'),      toDate(fecha_inscripcion, 'yyyy/MM/dd'),      toDate(fecha_inscripcion, 'dd-MMM-yyyy'),     toDate(fecha_inscripcion, 'MMMM dd, yyyy'),     toDate(fecha_inscripcion, \"dd 'de' MMMM 'de' yyyy\") ),",
				"          semana_gestacion = toInteger(semana_gestacion)) ~> derivedColumn4",
				"source5 derive(ci_beneficiaria = (regexReplace(toString(ci_beneficiaria), '[^0-9.]', '')),",
				"          monto_bs = toDecimal(monto_bs),",
				"          fecha_pago = coalesce( \r",
				"    toDate(fecha_pago, 'yyyy-MM-dd'), \r",
				"    toDate(fecha_pago, 'dd/MM/yyyy'), \r",
				"    toDate(fecha_pago, 'MM-dd-yyyy'), \r",
				"    toDate(fecha_pago, 'yyyy/MM/dd'), \r",
				"    toDate(fecha_pago, 'dd-MMM-yyyy'),\r",
				"    toDate(fecha_pago, 'MMMM dd, yyyy'),\r",
				"    toDate(fecha_pago, \"dd 'de' MMMM 'de' yyyy\")\r",
				"),",
				"          concepto_pago = initCap(lower(concepto_pago)),",
				"          estado_pago = initCap(lower(estado_pago)),",
				"          canal_pago = initCap(lower(canal_pago))) ~> derivedColumn5",
				"source6 derive(ci_madre =  (regexReplace(toString(ci_madre), '[^0-9.]', '')),",
				"          ci_recien_nacido = (regexReplace(toString(ci_recien_nacido), '[^0-9.]', '')),",
				"          peso_nacimiento_kg = toDecimal(peso_nacimiento_kg),",
				"          talla_nacimiento_cm = toDecimal(talla_nacimiento_cm),",
				"          fecha_parto = coalesce( \r",
				"    toDate(fecha_parto, 'yyyy-MM-dd'), \r",
				"    toDate(fecha_parto, 'dd/MM/yyyy'), \r",
				"    toDate(fecha_parto, 'MM-dd-yyyy'), \r",
				"    toDate(fecha_parto, 'yyyy/MM/dd'), \r",
				"    toDate(fecha_parto, 'dd-MMM-yyyy'),\r",
				"    toDate(fecha_parto, 'MMMM dd, yyyy'),\r",
				"    toDate(fecha_parto, \"dd 'de' MMMM 'de' yyyy\")\r",
				"),",
				"          tipo_parto = case(\r",
				"  in(['Nattural','nORMAL','normal','Nrmal','Noraml','NORMAL'], tipo_parto), 'Natural',\r",
				"  in(['Cessárea','cesárea'], tipo_parto), 'Cesárea',\r",
				"  tipo_parto\r",
				")) ~> derivedColumn6"
			]
		}
	}
}